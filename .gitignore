# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environment (single shared, at repo root)
.venv/
venv/
env/

# Data generation — generated data (large, re-run pipeline to regenerate)
data_gen/clean_images/
data_gen/dataset/
data_gen/data/failed_urls.txt
data_gen/*.egg-info/

# Training runs — ignore everything except the canonical example run
training/runs/removal_256/
training/runs/segmentation/
training/runs/removal_512/*/
!training/runs/removal_512/removal_512__20260415_220210/
# Never commit checkpoint weights, even inside the example run
training/runs/removal_512/removal_512__20260415_220210/artifacts/checkpoints/*.pth

# Preprocessed stores — always regenerated locally, never committed
data_gen/preprocessed_store/

# Auto-generated dashboard configs (written at run-start, never hand-edited)
training/configs/dashboard/.generated/

# Inference outputs
training/result*.png
training/result*.jpg
training/output/

# Frontend
node_modules/

# IDE
.idea/
.vscode/
*.iml
.claude/

# OS
.DS_Store
Thumbs.db
